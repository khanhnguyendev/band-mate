{
  "name": "band-mate",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:push": "supabase db push && pnpm --filter @band-mate/api db:generate",
    "db:migrate:deploy": "pnpm --filter @band-mate/api db:migrate:deploy",
    "db:generate": "pnpm --filter @band-mate/api db:generate",
    "db:seed": "pnpm --filter @band-mate/api db:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3"
}
