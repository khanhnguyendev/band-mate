# Copy this file to apps/api/.env and apps/web/.env.local and fill in the values.
# Never commit .env or .env.local to version control.

# ─── apps/api/.env ────────────────────────────────────────────────────────────

NODE_ENV=development
API_PORT=4000

# Database — Supabase (direct connection for Prisma migrations + runtime)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Optional: pooler URL for high-concurrency production deployments
# DATABASE_URL_POOLER=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase — service role key (server-side only, never expose to browser)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Redis — Upstash (Redis protocol URL for BullMQ)
# Format: rediss://default:<token>@<host>.upstash.io:6379
UPSTASH_REDIS_URL=rediss://default:[token]@[host].upstash.io:6379

# AI scoring — Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Transcription — OpenAI Whisper (speaking module)
OPENAI_API_KEY=sk-...

# Payments (not required for local dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=

# Feature flags (enable Phase 2 modules)
FEATURE_READING=false
FEATURE_LISTENING=false

# ─── apps/web/.env.local ──────────────────────────────────────────────────────

# Supabase — public/anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# API URL — server-side (used in server components, not exposed to browser)
API_URL=http://localhost:4000

# API URL — client-side (used in client components, must be publicly reachable)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Feature flags (mirror the API flags for UI gating)
NEXT_PUBLIC_FEATURE_READING=false
NEXT_PUBLIC_FEATURE_LISTENING=false

# Observability
NEXT_PUBLIC_SENTRY_DSN=
