# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# App
NODE_ENV=development
API_PORT=4000

# Auth
JWT_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars

# Database — Supabase
# Use DATABASE_URL (direct) for Prisma migrations
# Use DATABASE_URL_POOLER (PgBouncer) for API runtime
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL_POOLER=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Redis — Upstash
UPSTASH_REDIS_URL=rediss://[username]:[password]@[host].upstash.io:6379
UPSTASH_REDIS_TOKEN=

# Supabase Storage
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
STORAGE_AUDIO_BUCKET=audio-submissions

# AI scoring
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# Transcription
TRANSCRIPTION_API_KEY=

# Payments (required for production)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend (set in Vercel environment, not here)
# NEXT_PUBLIC_API_URL=http://localhost:4000/v1
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gamification
BONUS_CREDIT_EXPIRY_DAYS=90

# Feature flags
FEATURE_READING=false
FEATURE_LISTENING=false
