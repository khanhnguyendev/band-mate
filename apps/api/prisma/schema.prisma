generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  learner
  admin
}

enum Skill {
  writing
  speaking
  reading
  listening
}

enum LedgerEntryType {
  reserve
  consume
  refund
  grant
  topup
  expire
}

enum TaskType {
  task1
  task2
  part1
  part2
  part3
}

enum Difficulty {
  band5
  band6
  band7
  band8
}

enum SubmissionStatus {
  queued
  transcribing
  scoring
  completed
  failed
}

enum ScoringJobType {
  transcription
  scoring
}

enum ScoringJobStatus {
  pending
  running
  completed
  failed
  dead
}

// ─── Core user & wallet models ─────────────────────────────────────────────────

// Users are created in Supabase Auth; this table stores app-level profile data.
model User {
  id                    String    @id @default(uuid())
  supabaseUserId        String    @unique @map("supabase_user_id")
  email                 String    @unique
  name                  String
  role                  UserRole  @default(learner)
  targetBand            Decimal?  @map("target_band") @db.Decimal(2, 1)
  testDate              DateTime? @map("test_date") @db.Date
  weakSkills            Skill[]   @map("weak_skills")
  motivation            String?
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  wallet          Wallet?
  subscription    Subscription?
  submissions     Submission[]
  scoreReports    ScoreReport[]
  improvementTasks ImprovementTask[]

  @@map("users")
}

model Plan {
  id                 String   @id @default(uuid())
  name               String   @unique
  monthlyCredits     Int      @map("monthly_credit_grant")
  writingCreditCost  Int      @map("writing_credit_cost")
  speakingCreditCost Int      @map("speaking_credit_cost")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  planId               String   @map("plan_id")
  status               String   @default("active")
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Wallet {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  balance        Int       @default(0)
  bonusBalance   Int       @default(0) @map("bonus_balance")
  bonusExpiresAt DateTime? @map("bonus_expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id])
  entries LedgerEntry[]

  @@map("wallets")
}

model LedgerEntry {
  id             String          @id @default(uuid())
  walletId       String          @map("wallet_id")
  type           LedgerEntryType
  amount         Int
  balanceAfter   Int             @map("balance_after")
  description    String
  referenceId    String?         @map("reference_id") @db.Uuid
  idempotencyKey String          @unique @map("idempotency_key")
  createdAt      DateTime        @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@map("ledger_entries")
}

// ─── Content models ────────────────────────────────────────────────────────────

model QuestionSet {
  id               String     @id @default(uuid())
  skill            Skill
  title            String
  taskType         TaskType   @map("task_type")
  difficulty       Difficulty
  estimatedMinutes Int        @map("estimated_minutes")
  isPublished      Boolean    @default(true) @map("is_published")
  createdAt        DateTime   @default(now()) @map("created_at")

  questions Question[]

  @@map("question_sets")
}

model Question {
  id        String   @id @default(uuid())
  setId     String   @map("set_id")
  prompt    String
  mediaUrl  String?  @map("media_url")
  answerKey Json?    @map("answer_key")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  set         QuestionSet  @relation(fields: [setId], references: [id])
  submissions Submission[]

  @@map("questions")
}

// ─── Submission & scoring models ───────────────────────────────────────────────

model Submission {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  questionId    String           @map("question_id")
  skill         Skill
  status        SubmissionStatus @default(queued)
  inputText     String?          @map("input_text")
  audioKey      String?          @map("audio_key")
  transcript    String?
  creditCost    Int              @map("credit_cost")
  reservationId String?          @map("reservation_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  question    Question     @relation(fields: [questionId], references: [id])
  scoringJobs ScoringJob[]
  report      ScoreReport?

  @@map("submissions")
}

model ScoringJob {
  id           String           @id @default(uuid())
  submissionId String           @map("submission_id")
  type         ScoringJobType
  status       ScoringJobStatus @default(pending)
  attempts     Int              @default(0)
  lastError    String?          @map("last_error")
  promptPackId String?          @map("prompt_pack_id")
  aiTokensUsed Int?             @map("ai_tokens_used")
  aiCostUsd    Decimal?         @map("ai_cost_usd") @db.Decimal(10, 6)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  submission Submission @relation(fields: [submissionId], references: [id])

  @@map("scoring_jobs")
}

model ScoreReport {
  id              String   @id @default(uuid())
  submissionId    String   @unique @map("submission_id")
  userId          String   @map("user_id")
  skill           Skill
  overallBand     Decimal  @map("overall_band") @db.Decimal(2, 1)
  rubricVersionId String?  @map("rubric_version_id")
  rawAiResponse   Json?    @map("raw_ai_response")
  isEstimate      Boolean  @default(true) @map("is_estimate")
  createdAt       DateTime @default(now()) @map("created_at")

  submission       Submission        @relation(fields: [submissionId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  criterionRows    CriterionRow[]
  improvementTasks ImprovementTask[]

  @@map("score_reports")
}

model CriterionRow {
  id            String  @id @default(uuid())
  reportId      String  @map("report_id")
  criterionName String  @map("criterion_name")
  band          Decimal @db.Decimal(2, 1)
  explanation   String
  strengths     String[]
  weaknesses    String[]

  report ScoreReport @relation(fields: [reportId], references: [id])

  @@map("criterion_rows")
}

model ImprovementTask {
  id          String    @id @default(uuid())
  reportId    String    @map("report_id")
  userId      String    @map("user_id")
  description String
  skill       Skill
  criterion   String?
  status      String    @default("pending")
  completedAt DateTime? @map("completed_at")

  report ScoreReport @relation(fields: [reportId], references: [id])
  user   User        @relation(fields: [userId], references: [id])

  @@map("improvement_tasks")
}

model PromptPack {
  id                 String   @id @default(uuid())
  skill              Skill
  version            String
  systemPrompt       String   @map("system_prompt")
  userPromptTemplate String   @map("user_prompt_template")
  rubricSchema       Json     @map("rubric_schema")
  isActive           Boolean  @default(false) @map("is_active")
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("prompt_packs")
}

// ─── Gamification models ───────────────────────────────────────────────────────

model QuestDefinition {
  id            String   @id @default(uuid())
  title         String
  description   String
  skill         Skill?
  action        String   // e.g. 'reading_complete', 'listening_complete', 'speaking_submit', 'writing_submit'
  requiredCount Int      @default(1) @map("required_count")
  rewardCredits Int      @default(1) @map("reward_credits")
  period        String   // 'daily' | 'weekly'
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("quest_definitions")
}

model GameConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("game_config")
}
